CREATE TRIGGER dbo.trigger_prevent_assignment_teaches
ON dbo.teaches
AFTER INSERT, UPDATE
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (
        SELECT 1
        FROM inserted i
        WHERE (
            SELECT COUNT(*)
            FROM dbo.teaches t
            WHERE t.ID = i.ID
              AND t.year = i.year
        ) > 2
    )
    BEGIN
        ROLLBACK TRANSACTION;
    END
END;
GO
